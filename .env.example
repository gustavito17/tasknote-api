PORT=3000
NODE_ENV=development

# Supabase — obtener desde: Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY   # usar service_role key (nunca la anon)

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_SECURE_RANDOM_SECRET
JWT_EXPIRES_IN=24h
